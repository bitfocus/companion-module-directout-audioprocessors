{
	"name": "directout-audioprocessors",
	"version": "1.1.0",
	"main": "dist/main.js",
	"type": "module",
	"scripts": {
		"postinstall": "husky",
		"format": "prettier -w .",
		"package": "run build && companion-module-build",
		"build": "rimraf dist && run build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"dev": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "run lint:raw ."
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-directout-audioprocessors.git"
	},
	"engines": {
		"node": "^22.14",
		"yarn": "^4.14"
	},
	"dependencies": {
		"@companion-module/base": "~1.12.1",
		"fast-json-patch": "^3.1.1"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.7.2",
		"@types/jest": "^30.0.0",
		"@types/node": "^22.19.19",
		"eslint": "^9.39.4",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"typescript": "~5.8.3",
		"typescript-eslint": "^8.60.0"
	},
	"prettier": "@companion-module/tools/.prettierrc.json",
	"lint-staged": {
		"*.{css,json,md,scss}": [
			"prettier --write"
		],
		"*.{ts,tsx,js,jsx}": [
			"yarn lint:raw --fix"
		]
	},
	"packageManager": "yarn@4.14.0"
}
